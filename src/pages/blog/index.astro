---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const fmtDate = (d: Date) =>
  d
    .toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
    .toUpperCase();
---

<Base
  title="Writing — Shivananda Sahu"
  description="Notes on building software in healthcare and finance — and on Sieve, in weekend-sized pieces."
  ogDescription="Notes on building software in healthcare and finance — and on Sieve, in weekend-sized pieces."
>
  <div class="container">

    <header class="nav fade d1">
      <a class="brand" href="/">Shivananda Sahu</a>
      <div class="right">
        <a href="/blog" aria-current="page">writing</a>
        <a href="/#focus">work</a>
        <a href="/#about">about</a>
        <span class="loc">bengaluru · in</span>
      </div>
    </header>

    <section class="fade d2" style="margin-bottom: 72px;">
      <p class="s-label">§ writing</p>
      <h1 class="s-head">Notes from the workbench.</h1>
      <p class="hero-intro">Weekends spent building, and the thinking that comes out of them. Mostly Sieve right now — financial health for households that won't fit in one app.</p>
    </section>

    <section class="fade d3">
      <ul class="blog-list">
        {posts.map((post) => (
          <li class="blog-item">
            <div class="blog-meta">
              <span class="blog-date">{fmtDate(post.data.date)}</span>
              {post.data.category && (
                <span class="blog-tag">{post.data.category}</span>
              )}
            </div>
            <h2 class="blog-title">
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h2>
            <p class="blog-hook">{post.data.hook}</p>
            <a class="blog-readmore" href={`/blog/${post.id}`}>
              Read post
              {post.data.reading_time && (
                <>
                  <span class="blog-readmore-dot" aria-hidden="true">·</span>
                  <span class="blog-readmore-time">{post.data.reading_time} min</span>
                </>
              )}
              <span class="blog-readmore-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <footer>
      <p class="closer">If you've read this far, write back.</p>
      <ul class="contacts">
        <li><a href="mailto:sahu.shivanand@gmail.com">sahu.shivanand@gmail.com</a></li>
        <li><a href="https://www.linkedin.com/in/sshivananda/" target="_blank" rel="noopener">linkedin ↗</a></li>
        <li><a href="https://github.com/sshivananda" target="_blank" rel="noopener">github ↗</a></li>
      </ul>
      <p class="copy">© 2026 · bengaluru · in</p>
    </footer>

  </div>
</Base>
